# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

region   = "us-east-1"
repo_uri = "https://github.com/your-org/aws-hashi-knowledge-base"

# Optional overrides — defaults are safe for most deployments
# kendra_edition     = "ENTERPRISE_EDITION"   # or DEVELOPER_EDITION (~$810/mo)
# notification_email = ""                      # Set to receive CloudWatch alarm emails
# refresh_schedule   = "cron(0 2 ? * SUN *)"  # UTC
# scheduler_timezone = "Europe/London"
# force_destroy      = false                   # Set true only for non-production

# Neptune graph database (disabled by default)
# create_neptune          = false
# neptune_vpc_id          = "vpc-0123456789abcdef0"
# neptune_subnet_ids      = ["subnet-aaa", "subnet-bbb"]
# neptune_instance_class  = "db.r6g.large"
# neptune_instance_count  = 1
